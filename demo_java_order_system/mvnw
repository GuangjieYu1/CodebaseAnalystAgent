#!/bin/sh
set -e

BASE_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
PROPS_FILE="$WRAPPER_DIR/maven-wrapper.properties"

if [ ! -f "$PROPS_FILE" ]; then
  echo "Missing $PROPS_FILE" >&2
  exit 1
fi

DIST_URL=$(grep '^distributionUrl=' "$PROPS_FILE" | cut -d= -f2-)
DIST_FILE=$(basename "$DIST_URL")
DIST_NAME=$(printf '%s' "$DIST_FILE" | sed 's/-bin\.zip$//')
ARCHIVE_FILE="$WRAPPER_DIR/$DIST_FILE"
INSTALL_DIR="$WRAPPER_DIR/$DIST_NAME"
MVN_CMD="$INSTALL_DIR/bin/mvn"

if [ ! -x "$MVN_CMD" ]; then
  mkdir -p "$WRAPPER_DIR"

  if [ ! -f "$ARCHIVE_FILE" ]; then
    if command -v curl >/dev/null 2>&1; then
      curl -fsSL "$DIST_URL" -o "$ARCHIVE_FILE"
    elif command -v wget >/dev/null 2>&1; then
      wget -q "$DIST_URL" -O "$ARCHIVE_FILE"
    elif command -v mvn >/dev/null 2>&1; then
      exec mvn "$@"
    else
      echo "Unable to download Maven distribution. Install curl, wget, or Maven." >&2
      exit 1
    fi
  fi

  rm -rf "$INSTALL_DIR"
  unzip -q "$ARCHIVE_FILE" -d "$WRAPPER_DIR"
fi

exec "$MVN_CMD" "$@"
